# ═══════════════════════════════════════════════════════════════════════════════
# CrisisShield Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env with real secrets to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# "local" uses JSON file store; "postgres" uses real DB stack
STORAGE_MODE=postgres

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── Databases ────────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS (primary structured store)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crisisshield

# MongoDB (raw unstructured data store)
MONGODB_URL=mongodb://localhost:27017/crisisshield

# Elasticsearch (full-text search + filtering)
ELASTICSEARCH_URL=http://localhost:9200

# Redis (caching + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Kafka (streaming ingestion pipeline)
# Use kafka:9092 when running inside Docker Compose; localhost:29092 from host
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Authentication ───────────────────────────────────────────────────────────
# Generate a strong random key for production: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=crisisshield-dev-secret-CHANGE-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Admin Seed Account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@crisisshield.dev
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=CrisisShield Admin
ADMIN_ORGANIZATION=CrisisShield

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Anthropic API key for the LangChain recommendation engine
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=

# ── Notifications: Email (SMTP) ───────────────────────────────────────────────
# Used for CRITICAL and EMERGENCY alert emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@crisisshield.dev
SMTP_FROM_NAME=CrisisShield Alerts
# Comma-separated list of admin email addresses to receive alerts
ALERT_EMAIL_RECIPIENTS=admin@crisisshield.dev

# ── Notifications: SMS (Twilio) ───────────────────────────────────────────────
# Used for EMERGENCY alerts only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=+1234567890
# Comma-separated phone numbers for emergency SMS
ALERT_SMS_RECIPIENTS=

# ── Notifications: Webhook ────────────────────────────────────────────────────
# POST alert JSON to these URLs for integration with ISF or other systems
# Comma-separated list of URLs
ALERT_WEBHOOK_URLS=

# ── ML / MLflow ───────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
# Experiment names
MLFLOW_RISK_EXPERIMENT=crisisshield_risk_scoring
MLFLOW_ESCALATION_EXPERIMENT=crisisshield_escalation

# ── Alert Thresholds (stored in Redis on startup, tunable at runtime) ─────────
ALERT_THRESHOLD_INFO=40
ALERT_THRESHOLD_WARNING=60
ALERT_THRESHOLD_CRITICAL=80
ALERT_THRESHOLD_EMERGENCY=90
# Max risk velocity (points per hour) before triggering velocity alert
ALERT_VELOCITY_THRESHOLD=20
# Escalation probability threshold
ALERT_ESCALATION_PROBABILITY_THRESHOLD=0.8
# Rate limiting: seconds between same severity alert for same region
ALERT_RATE_LIMIT_SECONDS=3600

# ── Risk Scoring Weights (must sum to 1.0; stored in Redis on startup) ────────
RISK_WEIGHT_SENTIMENT=0.25
RISK_WEIGHT_VOLUME=0.25
RISK_WEIGHT_KEYWORD=0.20
RISK_WEIGHT_BEHAVIOR=0.15
RISK_WEIGHT_GEOSPATIAL=0.15
# How often to recalculate risk scores (minutes)
RISK_RECALC_INTERVAL_MINUTES=15

# ── NLP Pipeline ─────────────────────────────────────────────────────────────
# HuggingFace model cache directory (set to a persistent volume in production)
HF_HOME=/tmp/huggingface_cache
# Disable HuggingFace tokenizers parallelism warning
TOKENIZERS_PARALLELISM=false

# ── Data Ingestion ────────────────────────────────────────────────────────────
LIVE_NEWS_ENABLED=true
LIVE_NEWS_WINDOW_HOURS=48
LIVE_NEWS_LIMIT=100
OFFICIAL_FEEDS_ENABLED=true
OFFICIAL_FEED_LIMIT=50
OFFICIAL_FEED_EXTRA_CHANNELS_JSON=
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_REQUEST_TIMEOUT_SECONDS=15

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://127.0.0.1:8080","http://localhost:8080","http://127.0.0.1:3000","http://localhost:3000"]

# ── Local Dev Fallback ────────────────────────────────────────────────────────
# Path to local JSON state file (used when STORAGE_MODE=local)
LOCAL_DATA_FILE=backend/data/local_state.json
