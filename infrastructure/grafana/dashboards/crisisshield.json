{
  "title": "CrisisShield — System Overview",
  "uid": "crisisshield-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"crisisshield-backend\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"crisisshield-backend\"}[5m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"crisisshield-backend\",status=~\"5..\"}[1m])",
          "legendFormat": "5xx errors"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}] } }
      }
    },
    {
      "id": 4,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "crisisshield_websocket_connections_active", "legendFormat": "Connections" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}] } }
      }
    },
    {
      "id": 5,
      "title": "Incidents Processed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "increase(crisisshield_incidents_processed_total[24h])", "legendFormat": "Incidents" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      }
    },
    {
      "id": 6,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "kafka_consumer_lag_sum", "legendFormat": "Consumer lag" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}] } }
      }
    },
    {
      "id": 7,
      "title": "NLP Pipeline Processing Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(crisisshield_nlp_processing_seconds_bucket[5m]))",
          "legendFormat": "p95 NLP latency"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Risk Score by Region (latest)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "crisisshield_risk_score_current", "legendFormat": "{{region}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 40}, {"color": "orange", "value": 60}, {"color": "red", "value": 80}] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
